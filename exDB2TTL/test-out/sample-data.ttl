@prefix ns1: <http://example.com/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.com/data/orders/O100> a ns1:Order ;
    ns1:amount 120.5 ;
    ns1:belongsToCustomer <http://example.com/data/customers/C001> ;
    ns1:orderId "O100"^^xsd:string ;
    ns1:status "paid"^^xsd:string .

<http://example.com/data/orders/O101> a ns1:Order ;
    ns1:amount 99.0 ;
    ns1:belongsToCustomer <http://example.com/data/customers/C001> ;
    ns1:orderId "O101"^^xsd:string ;
    ns1:status "pending"^^xsd:string .

<http://example.com/data/orders/O102> a ns1:Order ;
    ns1:amount 210.0 ;
    ns1:belongsToCustomer <http://example.com/data/customers/C002> ;
    ns1:orderId "O102"^^xsd:string ;
    ns1:status "paid"^^xsd:string .

<http://example.com/data/customers/C002> a ns1:Customer ;
    ns1:city "Shenzhen"^^xsd:string ;
    ns1:customerId "C002"^^xsd:string ;
    ns1:customerName "Bob"^^xsd:string .

<http://example.com/data/customers/C001> a ns1:Customer ;
    ns1:city "Shanghai"^^xsd:string ;
    ns1:customerId "C001"^^xsd:string ;
    ns1:customerName "Alice"^^xsd:string .

