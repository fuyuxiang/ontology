    doim: a owl:Ontology ;
        rdfs:label "DOIM Core Ontology"@en ;
        rdfs:comment "Unified DOIM core ontology for the Python ontology semantic layer."@en .

    doim:evidenceFrom a owl:ObjectProperty ;
        rdfs:label "evidence from"@en ;
        rdfs:domain doim:Entity ;
        rdfs:range doim:Entity .

    doim:fromEntity a owl:ObjectProperty ;
        rdfs:label "from entity"@en ;
        rdfs:domain doim:Relation ;
        rdfs:range doim:Entity .

    doim:hasIdentifier a owl:ObjectProperty ;
        rdfs:label "has identifier"@en ;
        rdfs:domain doim:Entity ;
        rdfs:range doim:Identifier .

    doim:identifierValue a owl:DatatypeProperty ;
        rdfs:label "identifier value"@en ;
        rdfs:domain doim:Identifier ;
        rdfs:range xsd:string .

    doim:loadBatch a owl:DatatypeProperty ;
        rdfs:label "load batch"@en ;
        rdfs:domain doim:Entity ;
        rdfs:range xsd:string .

    doim:predicateUri a owl:DatatypeProperty ;
        rdfs:label "predicate URI"@en ;
        rdfs:domain doim:Relation ;
        rdfs:range xsd:anyURI .

    doim:relatedTo a owl:ObjectProperty ;
        rdfs:label "related to"@en ;
        rdfs:domain doim:Entity ;
        rdfs:range doim:Entity .

    doim:sourceSystem a owl:DatatypeProperty ;
        rdfs:label "source system"@en ;
        rdfs:domain doim:Entity ;
        rdfs:range xsd:string .

    doim:taggedByRule a owl:ObjectProperty ;
        rdfs:label "tagged by rule"@en ;
        rdfs:domain doim:Entity ;
        rdfs:range doim:Entity .

    doim:toEntity a owl:ObjectProperty ;
        rdfs:label "to entity"@en ;
        rdfs:domain doim:Relation ;
        rdfs:range doim:Entity .

    telecom:RiskAlert a owl:Class ;
        rdfs:label "Risk Alert"@en ;
        rdfs:subClassOf doim:Entity .

    telecom:RiskFactor a owl:Class ;
        rdfs:label "Risk Factor"@en ;
        rdfs:subClassOf doim:Entity .

