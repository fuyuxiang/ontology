@prefix doim: <http://purl.org/doim/1.0#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix telecom: <http://example.com/telecom#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<urn:doim:poc:base> {
    telecom: a owl:Ontology ;
        rdfs:label "Telecom Porting Ontology"@en ;
        rdfs:comment "Carrier porting risk ontology for the Python implementation."@en .

    telecom:Rule a owl:Class ;
        rdfs:label "Rule"@en ;
        rdfs:subClassOf doim:Entity .

    telecom:channelName a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:city a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:competitorContactCount30d a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:complaintCount30d a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:contractRemainingDays a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:dataUsageDropPct a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:eventDaysAgo a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:eventDetail a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:eventId a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:eventSeverity a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:eventType a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:generatedAlert a owl:ObjectProperty ;
        rdfs:domain telecom:Subscriber ;
        rdfs:range telecom:RiskAlert .

    telecom:hasCommercialSnapshot a owl:ObjectProperty ;
        rdfs:domain telecom:Subscriber ;
        rdfs:range telecom:CommercialSnapshot .

    telecom:hasInteraction a owl:ObjectProperty ;
        rdfs:domain telecom:Subscriber ;
        rdfs:range telecom:ChannelInteraction .

    telecom:hasRiskFactor a owl:ObjectProperty ;
        rdfs:domain telecom:Subscriber ;
        rdfs:range telecom:RiskFactor .

    telecom:hasUsageSnapshot a owl:ObjectProperty ;
        rdfs:domain telecom:Subscriber ;
        rdfs:range telecom:UsageSnapshot .

    telecom:inferredRiskLevel a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:monthlyFee a owl:DatatypeProperty ;
        rdfs:range xsd:decimal .

    telecom:networkIssueCount30d a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:npsScore a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:overdueDays a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:ownsNumber a owl:ObjectProperty ;
        rdfs:domain telecom:Subscriber ;
        rdfs:range telecom:MobileNumber .

    telecom:paymentRiskLevel a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:planName a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:portingCodeRequestCount30d a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:recommendedAction a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:retentionOfferRejected a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:riskLevel a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:riskScore a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:segmentName a owl:DatatypeProperty ;
        rdfs:range xsd:string .

    telecom:serviceTicketCount30d a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:subscriberId a owl:DatatypeProperty ;
        rdfs:domain telecom:Subscriber ;
        rdfs:range xsd:string .

    telecom:tenureMonths a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:vipFlag a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    telecom:voiceUsageDropPct a owl:DatatypeProperty ;
        rdfs:range xsd:integer .

    <http://example.com/telecom/data/relation/S1001-commercial> a doim:Relation ;
        rdfs:label "关联商业快照" ;
        doim:fromEntity <http://example.com/telecom/data/subscriber/S1001> ;
        doim:loadBatch "20260320022721" ;
        doim:predicateUri "http://example.com/telecom#hasCommercialSnapshot" ;
        doim:sourceSystem "BILLING" ;
        doim:toEntity <http://example.com/telecom/data/commercial/S1001> .

