# Jena Rules for Number Portability Churn Prediction
# 基于本体语义层技术方案的推理规则
@prefix doim: <http://purl.org/doim/1.0#>.
@prefix telecom: <http://example.org/telecom/1.0#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

# ===== 规则1: 高风险预警规则 =====
# 入网时长 < 6个月 且 投诉次数 >= 3 → 高风险
[ruleHighRisk1:
 (?sub rdf:type doim:Subscriber)
 (?sub doim:subscriptionMonths ?months)
 (?sub doim:complaintCount ?count)
 lessThan(?months, 6)
 greaterThanOrEqual(?count, 3)
 ->
 (?sub doim:churnRiskScore 80)
 (?alert rdf:type doim:Alert)
 (?alert doim:alertLevel "高")
 (?alert doim:alertTime now())
 (?sub doim:hasAlert ?alert)
]

# ===== 规则2: 高消费低时长风险规则 =====
# 月消费 > 100元 且 入网时长 < 12个月 → 中高风险
[ruleHighRisk2:
 (?sub rdf:type doim:Subscriber)
 (?sub doim:hasBillingRecord ?bill)
 (?bill doim:monthlyBill ?amount)
 (?sub doim:subscriptionMonths ?months)
 greaterThan(?amount, 100)
 lessThan(?months, 12)
 ->
 (?sub doim:churnRiskScore 65)
]

# ===== 规则3: 多次投诉风险规则 =====
# 投诉次数 >= 3 → 高风险
[ruleHighRisk3:
 (?sub rdf:type doim:Subscriber)
 (?sub doim:complaintCount ?count)
 greaterThanOrEqual(?count, 3)
 ->
 (?sub doim:churnRiskScore 75)
]

# ===== 规则4: 已申请转网立即预警 =====
# 申请携号转网 → 立即生成预警
[rulePortabilityAlert:
 (?sub rdf:type doim:Subscriber)
 (?sub doim:applyPortability ?app)
 (?app rdf:type doim:PortabilityApplication)
 ->
 (?alert rdf:type doim:Alert)
 (?alert doim:alertLevel "紧急")
 (?alert doim:alertTime now())
 (?sub doim:hasAlert ?alert)
]

# ===== 规则5: 长期稳定用户识别 =====
# 入网 >= 36个月 且 投诉次数 <= 1 → 低风险
[ruleStableUser:
 (?sub rdf:type doim:Subscriber)
 (?sub doim:subscriptionMonths ?months)
 (?sub doim:complaintCount ?count)
 greaterThanOrEqual(?months, 36)
 lessThanOrEqual(?count, 1)
 ->
 (?sub doim:churnRiskScore 20)
]

# ===== 规则6: 套餐性价比计算 =====
# 高套餐价格 + 低入网时长 = 潜在流失风险
[rulePackageRisk:
 (?sub rdf:type doim:Subscriber)
 (?sub doim:subscribesPackage ?pkg)
 (?pkg doim:packagePrice ?price)
 (?sub doim:subscriptionMonths ?months)
 greaterThan(?price, 150)
 lessThan(?months, 6)
 ->
 (?sub doim:churnRiskScore 70)
]

# ===== 规则7: 推理关联：用户手机号 =====
# 用户 → hasNumber → PhoneNumber → belongsToOperator
[rulePhoneOperator:
 (?sub rdf:type doim:Subscriber)
 (?sub doim:hasNumber ?phone)
 (?phone doim:belongsToOperator ?op)
 ->
 (?sub doim:currentOperator ?op)
]
