@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix doim: <http://purl.org/doim/1.0#> .

doim: rdf:type owl:Ontology ;
    rdfs:label "DOIM Core Ontology"@en ;
    rdfs:comment "Unified DOIM core ontology for the Python ontology semantic layer."@en .

doim:Entity rdf:type owl:Class ;
    rdfs:label "Entity"@en .

doim:Identifier rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Identifier"@en .

doim:Relation rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Relation"@en .

doim:hasIdentifier rdf:type owl:ObjectProperty ;
    rdfs:domain doim:Entity ;
    rdfs:range doim:Identifier ;
    rdfs:label "has identifier"@en .

doim:identifierValue rdf:type owl:DatatypeProperty ;
    rdfs:domain doim:Identifier ;
    rdfs:range xsd:string ;
    rdfs:label "identifier value"@en .

doim:sourceSystem rdf:type owl:DatatypeProperty ;
    rdfs:domain doim:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "source system"@en .

doim:loadBatch rdf:type owl:DatatypeProperty ;
    rdfs:domain doim:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "load batch"@en .

doim:fromEntity rdf:type owl:ObjectProperty ;
    rdfs:domain doim:Relation ;
    rdfs:range doim:Entity ;
    rdfs:label "from entity"@en .

doim:toEntity rdf:type owl:ObjectProperty ;
    rdfs:domain doim:Relation ;
    rdfs:range doim:Entity ;
    rdfs:label "to entity"@en .

doim:relatedTo rdf:type owl:ObjectProperty ;
    rdfs:domain doim:Entity ;
    rdfs:range doim:Entity ;
    rdfs:label "related to"@en .

doim:predicateUri rdf:type owl:DatatypeProperty ;
    rdfs:domain doim:Relation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "predicate URI"@en .

doim:taggedByRule rdf:type owl:ObjectProperty ;
    rdfs:domain doim:Entity ;
    rdfs:range doim:Entity ;
    rdfs:label "tagged by rule"@en .

doim:evidenceFrom rdf:type owl:ObjectProperty ;
    rdfs:domain doim:Entity ;
    rdfs:range doim:Entity ;
    rdfs:label "evidence from"@en .

