    rdfs:range xsd:string .

telecom:netType rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:callType rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:isTurn rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:servContent rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:acceptTime rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:solvedResult rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:custSatisfaction rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:complaintCount rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

telecom:callConnTime rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:callResult rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:isMaintainExec rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:isSuccessMaintain rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:turnReason rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:productName rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:inferredRiskLevel rdf:type owl:DatatypeProperty ;
