@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix doim: <http://purl.org/doim/1.0#> .
@prefix telecom: <http://example.com/telecom#> .

telecom: rdf:type owl:Ontology ;
    rdfs:label "Telecom Number Portability Ontology"@en ;
    rdfs:comment "Ontology for telecom number portability warning scenarios."@en .

telecom:User rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "User"@en .

telecom:PortingQuery rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Porting Eligibility"@en .

telecom:BusinessContract rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Business Contract"@en .

telecom:BillingRecord rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Billing Record"@en .

telecom:NetworkUsage rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Network Usage"@en .

telecom:CustomerServiceInteraction rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Customer Service Interaction"@en .

telecom:RetentionAction rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Retention Action"@en .

telecom:RiskFactor rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Risk Factor"@en .

telecom:Rule rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Rule"@en .

telecom:RiskAlert rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Risk Alert"@en .

telecom:RetentionCase rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Retention Case"@en .

telecom:Task rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Task"@en .

telecom:ActionDefinition rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Action Definition"@en .

telecom:ActionRun rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Action Run"@en .

telecom:DomainEvent rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "Domain Event"@en .

telecom:StateTransition rdf:type owl:Class ;
    rdfs:subClassOf doim:Entity ;
    rdfs:label "State Transition"@en .

telecom:hasPortingQuery rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:PortingQuery .

telecom:hasBusinessContract rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:BusinessContract .

telecom:hasBillingRecord rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:BillingRecord .

telecom:hasNetworkUsage rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:NetworkUsage .

telecom:hasCustomerServiceInteraction rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:CustomerServiceInteraction .

telecom:hasRetentionAction rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:RetentionAction .

telecom:restrictsPortingQuery rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:BusinessContract ;
    rdfs:range telecom:PortingQuery .

telecom:associatesBillingStatus rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:BillingRecord ;
    rdfs:range telecom:PortingQuery .

telecom:triggersRetentionAction rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:NetworkUsage ;
    rdfs:range telecom:RetentionAction .

telecom:influencesRetentionAction rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:CustomerServiceInteraction ;
    rdfs:range telecom:RetentionAction .

telecom:hasRiskFactor rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:RiskFactor .

telecom:generatedAlert rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:RiskAlert .

telecom:hasRetentionCase rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:User ;
    rdfs:range telecom:RetentionCase .

telecom:hasTask rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:RetentionCase ;
    rdfs:range telecom:Task .

telecom:availableAction rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:RetentionCase ;
    rdfs:range telecom:ActionDefinition .

telecom:hasActionRun rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:RetentionCase ;
    rdfs:range telecom:ActionRun .

telecom:usesActionDefinition rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:ActionRun ;
    rdfs:range telecom:ActionDefinition .

telecom:hasEvent rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:RetentionCase ;
    rdfs:range telecom:DomainEvent .

telecom:hasTransition rdf:type owl:ObjectProperty ;
    rdfs:domain telecom:RetentionCase ;
    rdfs:range telecom:StateTransition .

telecom:forCase rdf:type owl:ObjectProperty ;
    rdfs:range telecom:RetentionCase .

telecom:forAlert rdf:type owl:ObjectProperty ;
    rdfs:range telecom:RiskAlert .

telecom:userId rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:deviceNumber rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:areaId rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:userStatus rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:innetDate rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:userType rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:innetMonths rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

telecom:payMode rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:queryTime rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:outTag rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:limitRemark rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:queryChannel rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:queryStaff rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:activityType rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:startDate rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:endDate rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

telecom:preFee rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

telecom:presentFee rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

telecom:protocalMonth rdf:type owl:DatatypeProperty ;
