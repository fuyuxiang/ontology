        "data": {
          "label": "⓪ 本体查询 · 目标客户",
          "objectType": "Customer",
          "objectTypes": [
            "Customer",
            "Contract",
            "Segment",
            "Strategy",
            "TouchEvent",
            "Order"
          ],
          "filters": [
            "{\"property\":\"subscription_status\",\"operator\":\"!=\",\"value\":\"renewed\"}",
            "{\"property\":\"account_period_type\",\"operator\":\"IN\",\"value\":\"expired_unrenewed,expiring_t4plus,early_unsubscribe_unrenewed,other\"}",
            "{\"property\":\"is_blacklist\",\"operator\":\"==\",\"value\":\"false\"}",
            "{\"property\":\"arrears_status\",\"operator\":\"==\",\"value\":\"normal\"}",
            "{\"property\":\"BR-MOMENT-001 合约临期\",\"operator\":\"<=\",\"value\":\"contract_end_date - today ≤ 90d\"}",
            "{\"property\":\"BR-MOMENT-002 用量下降\",\"operator\":\"<\",\"value\":\"bandwidth_utilization < 0.3 持续 30d\"}",
            "{\"property\":\"BR-MOMENT-003 竞品威胁\",\"operator\":\"==\",\"value\":\"TouchEvent.objection_type='competitive_comparison' AND NOT resolved\"}",
            "{\"property\":\"BR-MOMENT-004 重试资格\",\"operator\":\">=\",\"value\":\"last_touch ≥ 30d 前 AND prev_result=FAILED\"}"
          ]
